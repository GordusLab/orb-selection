p <- ggplot(spl_res, aes(x=`abs(dPSI)`, y=`log10p`, color=`significant`)) +
geom_point() +
scale_color_manual(name="max p-value", values = cols) +
geom_line(aes(x=0.2), linetype="dashed", color="black") +
guides(colour = guide_legend(override.aes = list(linetype = 1))) +
labs(y=bquote(~-Log[10]~ '(max p-value)'))
